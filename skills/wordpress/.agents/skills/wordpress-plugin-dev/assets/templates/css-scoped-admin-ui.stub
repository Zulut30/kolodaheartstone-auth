.{{ROOT_CLASS}} {
	--{{PLUGIN_SLUG}}-gap: 16px;
	--{{PLUGIN_SLUG}}-border: #dcdcde;
	max-width: 960px;
}

.{{ROOT_CLASS}}__section {
	margin-block-start: var(--{{PLUGIN_SLUG}}-gap);
	padding: 16px;
	background: #fff;
	border: 1px solid var(--{{PLUGIN_SLUG}}-border);
}

.{{ROOT_CLASS}}__card-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	gap: var(--{{PLUGIN_SLUG}}-gap);
}

.{{ROOT_CLASS}} a:focus-visible,
.{{ROOT_CLASS}} button:focus-visible,
.{{ROOT_CLASS}} input:focus-visible,
.{{ROOT_CLASS}} select:focus-visible,
.{{ROOT_CLASS}} textarea:focus-visible {
	outline: 2px solid #2271b1;
	outline-offset: 2px;
}

@media (max-width: 600px) {
	.{{ROOT_CLASS}} {
		max-width: none;
	}
}
