<?php
/**
 * Classic Editor metabox fallback for {{PLUGIN_NAME}}.
 */

namespace {{VENDOR_NAMESPACE}}\{{PLUGIN_SLUG}}\Integrations;

final class ClassicEditorMetaboxFallback {
	public function register(): void {
		add_action( 'add_meta_boxes', array( $this, 'add_metabox' ) );
		add_action( 'save_post', array( $this, 'save' ), 10, 2 );
	}

	public function add_metabox(): void {
		add_meta_box(
			'{{PLUGIN_SLUG}}_metabox',
			esc_html__( '{{PLUGIN_NAME}}', '{{TEXT_DOMAIN}}' ),
			array( $this, 'render' ),
			'post',
			'side',
			'default'
		);
	}

	public function render( \WP_Post $post ): void {
		$value = (string) get_post_meta( $post->ID, '_{{PLUGIN_SLUG}}_value', true );
		wp_nonce_field( '{{PLUGIN_SLUG}}_save_metabox', '{{PLUGIN_SLUG}}_nonce' );
		?>
		<p>
			<label for="{{PLUGIN_SLUG}}_value"><?php echo esc_html__( 'Display label', '{{TEXT_DOMAIN}}' ); ?></label>
			<input id="{{PLUGIN_SLUG}}_value" name="{{PLUGIN_SLUG}}_value" type="text" class="widefat" value="<?php echo esc_attr( $value ); ?>" />
		</p>
		<?php
	}

	public function save( int $post_id, \WP_Post $post ): void {
		if ( wp_is_post_autosave( $post_id ) || wp_is_post_revision( $post_id ) ) {
			return;
		}

		if ( ! current_user_can( 'edit_post', $post_id ) ) {
			return;
		}

		$nonce = isset( $_POST['{{PLUGIN_SLUG}}_nonce'] ) ? sanitize_text_field( wp_unslash( $_POST['{{PLUGIN_SLUG}}_nonce'] ) ) : '';
		if ( ! wp_verify_nonce( $nonce, '{{PLUGIN_SLUG}}_save_metabox' ) ) {
			return;
		}

		$value = isset( $_POST['{{PLUGIN_SLUG}}_value'] ) ? sanitize_text_field( wp_unslash( $_POST['{{PLUGIN_SLUG}}_value'] ) ) : '';
		update_post_meta( $post_id, '_{{PLUGIN_SLUG}}_value', $value );
	}
}
