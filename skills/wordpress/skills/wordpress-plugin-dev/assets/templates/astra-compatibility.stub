<?php
namespace {{VENDOR_NAMESPACE}}\{{PLUGIN_SLUG}}\Integrations\Themes;

final class AstraCompatibility {
	public function detect(): bool {
		return 'astra' === wp_get_theme()->get_template();
	}

	public function register(): void {
		if ( ! $this->detect() ) {
			return;
		}
		// Verify current Astra hook docs before adding theme-specific placement.
		add_filter( '{{PLUGIN_SLUG}}_theme_adapter', static fn (): string => 'astra' );
	}
}
