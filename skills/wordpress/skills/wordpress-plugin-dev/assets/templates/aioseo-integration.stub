<?php
namespace {{VENDOR_NAMESPACE}}\{{PLUGIN_SLUG}}\Integrations\Seo;

use {{VENDOR_NAMESPACE}}\{{PLUGIN_SLUG}}\Integrations\IntegrationInterface;

final class AioseoIntegration implements IntegrationInterface {
	public function get_name(): string { return 'AIOSEO'; }

	public function detect(): bool {
		return defined( 'AIOSEO_VERSION' ) || class_exists( 'AIOSEO\\Plugin\\AIOSEO', false );
	}

	public function register(): void {
		// Verify current AIOSEO developer/filter docs before adding hooks.
		add_filter( '{{PLUGIN_SLUG}}_seo_provider', static fn (): string => 'aioseo' );
	}

	public function get_status(): string { return $this->detect() ? 'experimental' : 'not active'; }

	public function get_notes(): array { return array( 'Optional adapter; no duplicate meta/schema output.' ); }
}
