<?php
/**
 * Settings page for {{PLUGIN_NAME}}.
 *
 * @package {{VENDOR_NAMESPACE}}\{{PLUGIN_NAMESPACE}}
 */

namespace {{VENDOR_NAMESPACE}}\{{PLUGIN_NAMESPACE}}\Admin;

final class Settings_Page {
	private const OPTION = '{{PLUGIN_SLUG}}_settings';
	private const PAGE_SLUG = '{{PLUGIN_SLUG}}';
	private const CAPABILITY = 'manage_options';

	public function register(): void {
		add_action( 'admin_menu', array( $this, 'add_page' ) );
		add_action( 'admin_init', array( $this, 'register_settings' ) );
	}

	public function add_page(): void {
		add_options_page(
			__( '{{PLUGIN_NAME}}', '{{TEXT_DOMAIN}}' ),
			__( '{{PLUGIN_NAME}}', '{{TEXT_DOMAIN}}' ),
			self::CAPABILITY,
			self::PAGE_SLUG,
			array( $this, 'render' )
		);
	}

	public function register_settings(): void {
		register_setting(
			self::PAGE_SLUG,
			self::OPTION,
			array(
				'type'              => 'array',
				'sanitize_callback' => array( $this, 'sanitize_settings' ),
				'default'           => $this->get_defaults(),
				'show_in_rest'      => false,
			)
		);

		add_settings_section(
			'{{PLUGIN_SLUG}}_main',
			__( 'General settings', '{{TEXT_DOMAIN}}' ),
			'__return_false',
			self::PAGE_SLUG
		);

		add_settings_field(
			'message',
			__( 'Message', '{{TEXT_DOMAIN}}' ),
			array( $this, 'render_message_field' ),
			self::PAGE_SLUG,
			'{{PLUGIN_SLUG}}_main',
			array(
				'label_for' => self::OPTION . '_message',
			)
		);
	}

	public function sanitize_settings( $value ): array {
		$value = is_array( $value ) ? $value : array();

		return array(
			'message' => isset( $value['message'] ) ? sanitize_text_field( wp_unslash( $value['message'] ) ) : '',
		);
	}

	public function render_message_field( array $args ): void {
		$settings = wp_parse_args( get_option( self::OPTION, array() ), $this->get_defaults() );
		$field_id = isset( $args['label_for'] ) ? sanitize_key( $args['label_for'] ) : self::OPTION . '_message';

		printf(
			'<input class="regular-text" id="%1$s" type="text" name="%2$s[message]" value="%3$s" />',
			esc_attr( $field_id ),
			esc_attr( self::OPTION ),
			esc_attr( $settings['message'] )
		);

		printf(
			'<p class="description">%s</p>',
			esc_html__( 'Shown where the plugin renders its public message.', '{{TEXT_DOMAIN}}' )
		);
	}

	public function render(): void {
		if ( ! current_user_can( self::CAPABILITY ) ) {
			wp_die( esc_html__( 'You do not have permission to access this page.', '{{TEXT_DOMAIN}}' ) );
		}
		?>
		<div class="wrap">
			<h1><?php echo esc_html( get_admin_page_title() ); ?></h1>
			<form action="options.php" method="post">
				<?php
				settings_fields( self::PAGE_SLUG );
				do_settings_sections( self::PAGE_SLUG );
				submit_button( __( 'Save settings', '{{TEXT_DOMAIN}}' ) );
				?>
			</form>
		</div>
		<?php
	}

	private function get_defaults(): array {
		return array(
			'message' => '',
		);
	}
}
