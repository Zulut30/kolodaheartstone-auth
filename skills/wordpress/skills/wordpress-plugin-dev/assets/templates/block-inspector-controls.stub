import { InspectorControls } from '@wordpress/block-editor';
import { PanelBody, SelectControl, TextControl, ToggleControl } from '@wordpress/components';
import { __ } from '@wordpress/i18n';

export default function {{BLOCK_NAME}}InspectorControls( { attributes, setAttributes } ) {
	const { heading, layout, showMeta } = attributes;

	return (
		<InspectorControls>
			<PanelBody title={ __( 'Display settings', '{{TEXT_DOMAIN}}' ) } initialOpen={ true }>
				<TextControl
					label={ __( 'Heading', '{{TEXT_DOMAIN}}' ) }
					value={ heading || '' }
					onChange={ ( nextHeading ) => setAttributes( { heading: nextHeading } ) }
					help={ __( 'Shown above the block content.', '{{TEXT_DOMAIN}}' ) }
				/>
				<SelectControl
					label={ __( 'Layout', '{{TEXT_DOMAIN}}' ) }
					value={ layout || 'list' }
					options={ [
						{ label: __( 'List', '{{TEXT_DOMAIN}}' ), value: 'list' },
						{ label: __( 'Grid', '{{TEXT_DOMAIN}}' ), value: 'grid' },
					] }
					onChange={ ( nextLayout ) => setAttributes( { layout: nextLayout } ) }
				/>
				<ToggleControl
					label={ __( 'Show metadata', '{{TEXT_DOMAIN}}' ) }
					checked={ !! showMeta }
					onChange={ ( nextValue ) => setAttributes( { showMeta: nextValue } ) }
				/>
			</PanelBody>
		</InspectorControls>
	);
}
