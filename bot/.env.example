# Telegram bot token from @BotFather
BOT_TOKEN=

# WordPress site (no trailing slash)
WP_BASE_URL=https://kolodahearthstone.ru

# Bearer secret from WP admin -> VIP Locker -> Telegram бот
WP_BEARER=

# Telegram chat IDs (channel + group). User must be a member of at least one.
CHANNEL_ID=-1002311131780
GROUP_ID=-5001968053

# Paid subscription providers shown on the subscribe screen.
BOOSTY_URL=https://boosty.to/kolodahearthstone
TRIBUTE_URL=https://web.tribute.tg/s/xz9

# Optional: extra "Name|URL" pairs (comma-separated) shown alongside the
# providers above — e.g. direct invite links to the Telegram channel/group.
SUBSCRIBE_LINKS=

# Optional: HTTP timeout in seconds for WP requests
HTTP_TIMEOUT=10

# Optional: how often (sec) to re-pull /lockers + cache new covers.
# 0 disables the periodic refresh. Default 1800 (30 min).
REFRESH_INTERVAL_SEC=1800
